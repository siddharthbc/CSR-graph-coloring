// Picasso Graph Coloring on Cerebras WSE
// Layout: 1D array of PEs for speculative parallel graph coloring
// with on-fabric wavelet exchange (no host mediation between rounds).
//
// Uses checkerboard color routing for bidirectional east/west exchange:
//   - Even PEs send east on east_color_0, odd PEs send east on east_color_1
//   - Even PEs send west on west_color_1, odd PEs send west on west_color_0
// This avoids routing conflicts on shared colors.

param num_pes: i16;
param max_local_verts: i16;
param max_local_edges: i16;
param max_boundary: i16;
param palette_size: i16;
param max_rounds: i16;

// Four colors for checkerboard bidirectional exchange
const east_color_0: color = @get_color(0);
const east_color_1: color = @get_color(1);
const west_color_0: color = @get_color(2);
const west_color_1: color = @get_color(3);

const memcpy = @import_module("<memcpy/get_params>", .{
  .width = num_pes,
  .height = 1,
});

// Route shorthands
const RX_R_TX_E = .{ .rx = .{ RAMP }, .tx = .{ EAST } };
const RX_W_TX_R = .{ .rx = .{ WEST }, .tx = .{ RAMP } };
const RX_R_TX_W = .{ .rx = .{ RAMP }, .tx = .{ WEST } };
const RX_E_TX_R = .{ .rx = .{ EAST }, .tx = .{ RAMP } };

layout {
  @set_rectangle(num_pes, 1);

  for (@range(i16, num_pes)) |pe| {
    const west_edge = (pe == 0);
    const east_edge = (pe == num_pes - 1);

    // Checkerboard color assignment
    const color_params = if (pe % 2 == 0) .{
      .send_east_color = east_color_0,
      .send_west_color = west_color_1,
      .recv_east_color = west_color_0,
      .recv_west_color = east_color_1,
    } else .{
      .send_east_color = east_color_1,
      .send_west_color = west_color_0,
      .recv_east_color = west_color_1,
      .recv_west_color = east_color_0,
    };

    @set_tile_code(pe, 0, "pe_program.csl", @concat_structs(
      .{
        .memcpy_params = memcpy.get_params(pe),
        .pe_id = pe,
        .num_pes = num_pes,
        .max_local_verts = max_local_verts,
        .max_local_edges = max_local_edges,
        .max_boundary = max_boundary,
        .palette_size = palette_size,
        .max_rounds = max_rounds,
        .is_west_edge = west_edge,
        .is_east_edge = east_edge,
      },
      color_params,
    ));

    // Configure routes based on checkerboard parity
    if (pe % 2 == 0) {
      @set_color_config(pe, 0, east_color_0, .{ .routes = RX_R_TX_E });
      @set_color_config(pe, 0, east_color_1, .{ .routes = RX_W_TX_R });
      @set_color_config(pe, 0, west_color_0, .{ .routes = RX_E_TX_R });
      @set_color_config(pe, 0, west_color_1, .{ .routes = RX_R_TX_W });
    } else {
      @set_color_config(pe, 0, east_color_0, .{ .routes = RX_W_TX_R });
      @set_color_config(pe, 0, east_color_1, .{ .routes = RX_R_TX_E });
      @set_color_config(pe, 0, west_color_0, .{ .routes = RX_R_TX_W });
      @set_color_config(pe, 0, west_color_1, .{ .routes = RX_E_TX_R });
    }
  }

  // Export symbols for host communication
  @export_name("csr_offsets", [*]i32, true);
  @export_name("csr_adj", [*]i32, true);
  @export_name("colors", [*]i32, true);
  @export_name("local_num_verts", [*]i32, true);
  @export_name("global_vertex_ids", [*]i32, true);
  @export_name("boundary_local_idx", [*]i32, true);
  @export_name("boundary_neighbor_gid", [*]i32, true);
  @export_name("num_boundary", [*]i32, true);
  @export_name("expected_recv_east", [*]i32, true);
  @export_name("expected_recv_west", [*]i32, true);
  @export_name("start_coloring", fn()void);
}
