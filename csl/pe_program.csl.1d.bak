// PE kernel for speculative parallel graph coloring
// with on-fabric wavelet exchange and autonomous round loop.
//
// No host mediation between rounds. The host only:
//   1. Loads graph data (CSR, boundary info)
//   2. Calls start_coloring()
//   3. Waits for completion
//   4. Reads back colors[]
//
// Each round follows the BSP pattern via task chaining:
//
//   ┌──────────┐  ┌────────────────┐  ┌───────────────────────┐  ┌─────────────┐
//   │ Speculate ├─►│ Send Boundary  ├─►│ Recv Wavelets (async) ├─►│ Detect+Loop │
//   └──────────┘  └────────────────┘  └───────────────────────┘  └─────────────┘
//
// Barrier synchronization: each PE knows exactly how many boundary
// wavelets it expects to receive. When all have arrived (counted by
// data tasks), it proceeds to detect conflicts. This is the
// game-of-life pattern applied to graph coloring.

param memcpy_params: comptime_struct;
param pe_id: i16;
param num_pes: i16;
param max_local_verts: i16;
param max_local_edges: i16;
param max_boundary: i16;
param palette_size: i16;
param max_rounds: i16;

// Communication colors (checkerboard for bidirectional exchange)
param send_east_color: color;
param send_west_color: color;
param recv_east_color: color;
param recv_west_color: color;

param is_west_edge: bool;
param is_east_edge: bool;

// ---------- Queues ----------
const send_east_oq: output_queue = @get_output_queue(2);
const send_west_oq: output_queue = @get_output_queue(3);
const recv_east_iq: input_queue  = @get_input_queue(2);
const recv_west_iq: input_queue  = @get_input_queue(3);

// ---------- Task IDs ----------
const speculate_task_id:      local_task_id = @get_local_task_id(8);
const send_boundary_task_id:  local_task_id = @get_local_task_id(9);
const detect_resolve_task_id: local_task_id = @get_local_task_id(10);
const exit_task_id:           local_task_id = @get_local_task_id(11);

// Data task IDs for receiving wavelets from neighbors
const recv_east_task_id: data_task_id =
  if      (@is_arch("wse2")) @get_data_task_id(recv_east_color)
  else if (@is_arch("wse3")) @get_data_task_id(recv_east_iq);
const recv_west_task_id: data_task_id =
  if      (@is_arch("wse2")) @get_data_task_id(recv_west_color)
  else if (@is_arch("wse3")) @get_data_task_id(recv_west_iq);

const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);

// ===== Per-PE graph data (loaded from host once) =====

var csr_offsets: [max_local_verts + 1]i32;   // CSR row pointers (local)
var csr_adj: [max_local_edges]i32;            // CSR adjacency (global IDs)
var colors: [max_local_verts]i32;             // -1 = uncolored, >= 0 = confirmed
var local_num_verts: [1]i32;                  // actual vertex count on this PE
var global_vertex_ids: [max_local_verts]i32;  // local idx -> global vertex ID

// Boundary info (loaded from host once)
// boundary_local_idx[b]      = local index of the boundary vertex on this PE
// boundary_neighbor_gid[b]   = global ID of the remote neighbor
var boundary_local_idx: [max_boundary]i32;
var boundary_neighbor_gid: [max_boundary]i32;
var num_boundary: [1]i32;

// How many wavelets this PE expects to receive each round
var expected_recv_east: [1]i32;
var expected_recv_west: [1]i32;

// ===== Working state =====

var tentative: [max_local_verts]i32;          // tentative colors this round
var forbidden: [palette_size]i32;             // temp bitmap for greedy

// Remote neighbor colors received via wavelets this round
var remote_recv_color: [max_boundary]i32;

// Packed send buffers (wavelet u32 values staged before DMA)
var east_send_buf: [max_boundary]u32;
var west_send_buf: [max_boundary]u32;

// Counters for received wavelets (implicit barrier)
var num_recv_east: i32 = 0;
var num_recv_west: i32 = 0;
var current_round: i32 = 0;

// ===== Host symbol pointers =====

var csr_offsets_ptr: [*]i32 = &csr_offsets;
var csr_adj_ptr: [*]i32 = &csr_adj;
var colors_ptr: [*]i32 = &colors;
var local_num_verts_ptr: [*]i32 = &local_num_verts;
var global_vertex_ids_ptr: [*]i32 = &global_vertex_ids;
var boundary_local_idx_ptr: [*]i32 = &boundary_local_idx;
var boundary_neighbor_gid_ptr: [*]i32 = &boundary_neighbor_gid;
var num_boundary_ptr: [*]i32 = &num_boundary;
var expected_recv_east_ptr: [*]i32 = &expected_recv_east;
var expected_recv_west_ptr: [*]i32 = &expected_recv_west;

// =====================================================================
// Helper functions
// =====================================================================

/// Map a global vertex ID to its local index, or -1 if not on this PE.
fn global_to_local(gid: i32) i32 {
  const n = local_num_verts[0];
  var i: i16 = 0;
  while (i < max_local_verts) : (i += 1) {
    if (@as(i32, i) >= n) break;
    if (global_vertex_ids[i] == gid) return @as(i32, i);
  }
  return -1;
}

/// Find smallest color in [0, palette_size) not marked forbidden.
fn find_min_available_color() i32 {
  var c: i16 = 0;
  while (c < palette_size) : (c += 1) {
    if (forbidden[c] == 0) return @as(i32, c);
  }
  return -1;
}

/// Pack (vertex_global_id, color) into a single u32 wavelet.
/// High 16 bits = vertex ID, low 16 bits = color + 1 (so -1 maps to 0).
fn pack_wavelet(gid: i32, col: i32) u32 {
  const id_part = @as(u32, @as(u16, @as(i16, gid)));
  const col_part = @as(u32, @as(u16, @as(i16, col + 1)));
  return (id_part << 16) | col_part;
}

/// Unpack vertex global ID from wavelet.
fn unpack_gid(wval: u32) i32 {
  return @as(i32, @as(i16, @as(u16, wval >> 16)));
}

/// Unpack color from wavelet (-1 if was uncolored).
fn unpack_color(wval: u32) i32 {
  return @as(i32, @as(i16, @as(u16, wval & 0xFFFF))) - 1;
}

/// Check if all local vertices are colored.
fn all_colored() bool {
  const n = local_num_verts[0];
  var v: i16 = 0;
  while (v < max_local_verts) : (v += 1) {
    if (@as(i32, v) >= n) break;
    if (colors[v] < 0) return false;
  }
  return true;
}

/// Check if we've received all expected wavelets for this round.
fn all_wavelets_received() bool {
  return (num_recv_east >= expected_recv_east[0] and
          num_recv_west >= expected_recv_west[0]);
}

/// Store a received wavelet's color by matching sender's global ID
/// against our boundary table.
fn process_incoming_wavelet(sender_gid: i32, sender_color: i32) void {
  const nbnd = num_boundary[0];
  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    if (@as(i32, b) >= nbnd) break;
    if (boundary_neighbor_gid[b] == sender_gid) {
      remote_recv_color[b] = sender_color;
    }
  }
}

// =====================================================================
// Phase 1: Speculate — assign tentative colors to uncolored vertices
// =====================================================================

task speculate() void {
  const n = local_num_verts[0];

  // Assign tentative colors
  var v: i16 = 0;
  while (v < max_local_verts) : (v += 1) {
    if (@as(i32, v) >= n) break;
    tentative[v] = -1;

    if (colors[v] >= 0) continue; // already confirmed

    // Build forbidden set from confirmed neighbor colors
    var c: i16 = 0;
    while (c < palette_size) : (c += 1) {
      forbidden[c] = 0;
    }

    const start = csr_offsets[v];
    const end_idx = csr_offsets[v + 1];
    var e: i32 = start;
    while (e < end_idx) : (e += 1) {
      const neighbor_gid = csr_adj[@as(u16, @as(i16, e))];
      // Check local neighbors
      const local_idx = global_to_local(neighbor_gid);
      if (local_idx >= 0) {
        const nc = colors[@as(u16, @as(i16, local_idx))];
        if (nc >= 0 and nc < @as(i32, palette_size)) {
          forbidden[@as(u16, @as(i16, nc))] = 1;
        }
      } else {
        // Check remote colors from previous round's wavelets
        const nbnd = num_boundary[0];
        var b: i16 = 0;
        while (b < max_boundary) : (b += 1) {
          if (@as(i32, b) >= nbnd) break;
          if (boundary_neighbor_gid[b] == neighbor_gid) {
            const rc = remote_recv_color[b];
            if (rc >= 0 and rc < @as(i32, palette_size)) {
              forbidden[@as(u16, @as(i16, rc))] = 1;
            }
          }
        }
      }
    }

    const chosen = find_min_available_color();
    tentative[v] = chosen;
    if (chosen >= 0) {
      colors[v] = chosen; // tentatively commit
    }
  }

  // Local conflict check: for edges within this PE, higher global ID yields
  v = 0;
  while (v < max_local_verts) : (v += 1) {
    if (@as(i32, v) >= n) break;
    if (tentative[v] < 0) continue;

    const my_gid = global_vertex_ids[v];
    const start = csr_offsets[v];
    const end_idx = csr_offsets[v + 1];
    var e: i32 = start;
    while (e < end_idx) : (e += 1) {
      const neighbor_gid = csr_adj[@as(u16, @as(i16, e))];
      const local_idx = global_to_local(neighbor_gid);
      if (local_idx < 0) continue; // boundary -> handle after wavelets

      const li = @as(u16, @as(i16, local_idx));
      if (tentative[li] >= 0 and tentative[li] == tentative[v]) {
        if (my_gid > neighbor_gid) {
          colors[v] = -1;
          tentative[v] = -1;
          break;
        }
      }
    }
  }

  // Move to send phase
  @activate(send_boundary_task_id);
}

// =====================================================================
// Phase 2: Send boundary colors as wavelets to neighboring PEs
// =====================================================================

task send_boundary() void {
  const n = local_num_verts[0];
  const nbnd = num_boundary[0];

  // Pack wavelets into send buffers, separated by direction
  var east_count: u16 = 0;
  var west_count: u16 = 0;

  const my_first_gid = global_vertex_ids[0];
  const my_last_gid = global_vertex_ids[@as(u16, @as(i16, n - 1))];

  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    if (@as(i32, b) >= nbnd) break;
    const li = @as(u16, @as(i16, boundary_local_idx[b]));
    const nbr_gid = boundary_neighbor_gid[b];
    const wval = pack_wavelet(global_vertex_ids[li], colors[li]);

    if (nbr_gid > my_last_gid) {
      east_send_buf[east_count] = wval;
      east_count += 1;
    } else if (nbr_gid < my_first_gid) {
      west_send_buf[west_count] = wval;
      west_count += 1;
    }
  }

  // Single DMA transfer per direction (avoids per-wavelet @mov32 loop)
  if (!is_east_edge and east_count > 0) {
    var east_out = @get_dsd(fabout_dsd, .{
      .fabric_color = send_east_color,
      .extent = max_boundary,
      .output_queue = send_east_oq,
    });
    east_out = @set_dsd_length(east_out, east_count);
    var east_src = @get_dsd(mem1d_dsd, .{
      .tensor_access = |i|{max_boundary} -> east_send_buf[i],
    });
    east_src = @set_dsd_length(east_src, east_count);
    @mov32(east_out, east_src, .{ .async = true });
  }

  if (!is_west_edge and west_count > 0) {
    var west_out = @get_dsd(fabout_dsd, .{
      .fabric_color = send_west_color,
      .extent = max_boundary,
      .output_queue = send_west_oq,
    });
    west_out = @set_dsd_length(west_out, west_count);
    var west_src = @get_dsd(mem1d_dsd, .{
      .tensor_access = |i|{max_boundary} -> west_send_buf[i],
    });
    west_src = @set_dsd_length(west_src, west_count);
    @mov32(west_out, west_src, .{ .async = true });
  }

  // Now open the receive window for this round
  @unblock(recv_east_task_id);
  @unblock(recv_west_task_id);

  // If we expect no wavelets at all, go straight to detect
  if (all_wavelets_received()) {
    @block(recv_east_task_id);
    @block(recv_west_task_id);
    @activate(detect_resolve_task_id);
  }
}

// =====================================================================
// Data tasks: receive wavelets from neighboring PEs
// =====================================================================

task recv_east(wval: u32) void {
  process_incoming_wavelet(unpack_gid(wval), unpack_color(wval));
  num_recv_east += 1;
  if (all_wavelets_received()) {
    @block(recv_east_task_id);
    @block(recv_west_task_id);
    @activate(detect_resolve_task_id);
  }
}

task recv_west(wval: u32) void {
  process_incoming_wavelet(unpack_gid(wval), unpack_color(wval));
  num_recv_west += 1;
  if (all_wavelets_received()) {
    @block(recv_east_task_id);
    @block(recv_west_task_id);
    @activate(detect_resolve_task_id);
  }
}

// =====================================================================
// Phase 3: Detect boundary conflicts + resolve + loop
// =====================================================================

task detect_resolve() void {
  const nbnd = num_boundary[0];

  // Check each boundary edge for conflicts
  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    if (@as(i32, b) >= nbnd) break;

    const li = @as(u16, @as(i16, boundary_local_idx[b]));
    const my_gid = global_vertex_ids[li];
    const nbr_gid = boundary_neighbor_gid[b];

    const my_col = colors[li];
    const remote_col = remote_recv_color[b];

    // Both colored with same color? Conflict!
    if (my_col >= 0 and remote_col >= 0 and my_col == remote_col) {
      if (my_gid > nbr_gid) {
        colors[li] = -1; // higher ID yields
      }
    }
  }

  current_round += 1;

  // All PEs must run the same number of rounds (no early exit) to
  // avoid deadlock — an exited PE would stop sending wavelets while
  // its neighbor still expects them.
  if (current_round >= @as(i32, max_rounds)) {
    @activate(exit_task_id);
  } else {
    // Reset recv counters for next round
    // (recv tasks are already blocked by the recv handler)
    num_recv_east = 0;
    num_recv_west = 0;

    // Start next round — send_boundary will @unblock recv tasks
    @activate(speculate_task_id);
  }
}

// =====================================================================
// Entry point and exit
// =====================================================================

/// Called by host once. Kicks off the autonomous round loop.
fn start_coloring() void {
  // Initialize remote colors to -1 (unknown)
  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    remote_recv_color[b] = -1;
  }

  current_round = 0;
  num_recv_east = 0;
  num_recv_west = 0;

  // Recv tasks start blocked (comptime); send_boundary will unblock them.
  @activate(speculate_task_id);
}

task exit_task() void {
  sys_mod.unblock_cmd_stream();
}

comptime {
  @bind_local_task(speculate, speculate_task_id);
  @bind_local_task(send_boundary, send_boundary_task_id);
  @bind_local_task(detect_resolve, detect_resolve_task_id);
  @bind_local_task(exit_task, exit_task_id);

  @bind_data_task(recv_east, recv_east_task_id);
  @bind_data_task(recv_west, recv_west_task_id);

  // Block recv tasks initially — unblocked at start of each round
  @block(recv_east_task_id);
  @block(recv_west_task_id);

  if (@is_arch("wse3")) {
    @initialize_queue(send_east_oq, .{ .color = send_east_color });
    @initialize_queue(send_west_oq, .{ .color = send_west_color });
    @initialize_queue(recv_east_iq, .{ .color = recv_east_color });
    @initialize_queue(recv_west_iq, .{ .color = recv_west_color });
  }

  @export_symbol(csr_offsets_ptr, "csr_offsets");
  @export_symbol(csr_adj_ptr, "csr_adj");
  @export_symbol(colors_ptr, "colors");
  @export_symbol(local_num_verts_ptr, "local_num_verts");
  @export_symbol(global_vertex_ids_ptr, "global_vertex_ids");
  @export_symbol(boundary_local_idx_ptr, "boundary_local_idx");
  @export_symbol(boundary_neighbor_gid_ptr, "boundary_neighbor_gid");
  @export_symbol(num_boundary_ptr, "num_boundary");
  @export_symbol(expected_recv_east_ptr, "expected_recv_east");
  @export_symbol(expected_recv_west_ptr, "expected_recv_west");
  @export_symbol(start_coloring);
}
