// PE kernel for speculative parallel graph coloring
// with on-fabric wavelet exchange and autonomous round loop.
//
// Supports 1D (east/west only) and 2D (east/west/north/south) layouts.
// When num_rows == 1, all north/south code is eliminated at compile time.
// In 1D mode, a global hardware barrier ensures all PEs complete data
// exchange before any PE enters detect/resolve (true BSP).
//
// No host mediation between rounds. The host only:
//   1. Loads graph data (CSR, boundary info, boundary directions)
//   2. Calls start_coloring()
//   3. Waits for completion
//   4. Reads back colors[]
//
// Each round follows the BSP pattern via task chaining:
//   Speculate → Send Boundary → Recv Wavelets → BARRIER → Detect+Loop
//
// Barrier (1D mode):
//   Row-reduce (east→west) + broadcast (P0,0→all) using data tasks.
//   Each PE unblocks its sync reduce task only AFTER all data wavelets
//   have been received, ensuring the reduce signal only propagates
//   through PEs that are done with data exchange.
//
// Boundary direction encoding (host-computed, per boundary edge):
//   0 = east, 1 = west, 2 = south, 3 = north

param memcpy_params: comptime_struct;
param pe_id: i16;
param num_cols: i16;
param num_rows: i16;
param max_local_verts: i16;
param max_local_edges: i16;
param max_boundary: i16;
param palette_size: i16;
param max_rounds: i16;

// E/W communication colors (always used)
param send_east_color: color;
param send_west_color: color;
param recv_east_color: color;
param recv_west_color: color;

// N/S communication colors (used when num_rows > 1)
param send_south_color: color;
param send_north_color: color;
param recv_south_color: color;
param recv_north_color: color;

// Sync barrier colors (used in 1D mode when use_sync_barrier==true)
param sync_reduce_recv_color: color;  // row reduce: recv color for this PE
param sync_reduce_send_color: color;  // row reduce: send color for this PE
param sync_bcast_color: color;        // broadcast from P(0,0)
param use_sync_barrier: bool;         // true in 1D, false in 2D

// Edge flags
param is_west_edge: bool;
param is_east_edge: bool;
param is_north_edge: bool;
param is_south_edge: bool;

// ========== Queues ==========

// E/W queues (always used)
const send_east_oq: output_queue = @get_output_queue(2);
const send_west_oq: output_queue = @get_output_queue(3);
const recv_east_iq: input_queue  = @get_input_queue(2);
const recv_west_iq: input_queue  = @get_input_queue(3);

// N/S queues (used when num_rows > 1)
const send_south_oq: output_queue = @get_output_queue(4);
const send_north_oq: output_queue = @get_output_queue(5);
const recv_south_iq: input_queue  = @get_input_queue(4);
const recv_north_iq: input_queue  = @get_input_queue(5);

// Sync barrier queues (reuse queues 4,5 — free in 1D mode since no N/S)
const sync_reduce_recv_iq: input_queue  = @get_input_queue(4);
const sync_reduce_send_oq: output_queue = @get_output_queue(4);
const sync_bcast_recv_iq:  input_queue  = @get_input_queue(5);
const sync_bcast_send_oq:  output_queue = @get_output_queue(5);

// ========== Task IDs ==========

const speculate_task_id:      local_task_id = @get_local_task_id(15);
const send_boundary_task_id:  local_task_id = @get_local_task_id(16);
const detect_resolve_task_id: local_task_id = @get_local_task_id(17);
const exit_task_id:           local_task_id = @get_local_task_id(18);

// Sync barrier data task IDs (1D mode: recv on queues 4,5)
const sync_reduce_task_id: data_task_id =
  if (@is_arch("wse3")) @get_data_task_id(sync_reduce_recv_iq)
  else                   @get_data_task_id(sync_reduce_recv_color);
const sync_bcast_task_id: data_task_id =
  if (@is_arch("wse3")) @get_data_task_id(sync_bcast_recv_iq)
  else                   @get_data_task_id(sync_bcast_color);

// E/W data task IDs
const recv_east_task_id: data_task_id =
  if      (@is_arch("wse2")) @get_data_task_id(recv_east_color)
  else if (@is_arch("wse3")) @get_data_task_id(recv_east_iq);
const recv_west_task_id: data_task_id =
  if      (@is_arch("wse2")) @get_data_task_id(recv_west_color)
  else if (@is_arch("wse3")) @get_data_task_id(recv_west_iq);

// N/S data task IDs (bound only when num_rows > 1)
const recv_south_task_id: data_task_id =
  if      (@is_arch("wse2")) @get_data_task_id(recv_south_color)
  else if (@is_arch("wse3")) @get_data_task_id(recv_south_iq);
const recv_north_task_id: data_task_id =
  if      (@is_arch("wse2")) @get_data_task_id(recv_north_color)
  else if (@is_arch("wse3")) @get_data_task_id(recv_north_iq);

const sys_mod = @import_module("<memcpy/memcpy>", memcpy_params);

// ===== Per-PE graph data (loaded from host once) =====

var csr_offsets: [max_local_verts + 1]i32;
var csr_adj: [max_local_edges]i32;
var colors: [max_local_verts]i32;
var local_num_verts: [1]i32;
var global_vertex_ids: [max_local_verts]i32;

// Boundary info
var boundary_local_idx: [max_boundary]i32;
var boundary_neighbor_gid: [max_boundary]i32;
var boundary_direction: [max_boundary]i32;   // 0=E, 1=W, 2=S, 3=N
var num_boundary: [1]i32;

// Expected wavelet counts per direction (implicit barrier)
var expected_recv_east: [1]i32;
var expected_recv_west: [1]i32;
var expected_recv_south: [1]i32;
var expected_recv_north: [1]i32;

// ===== Working state =====

var tentative: [max_local_verts]i32;
var forbidden: [palette_size]i32;
var remote_recv_color: [max_boundary]i32;

// Packed send buffers per direction
var east_send_buf: [max_boundary]u32;
var west_send_buf: [max_boundary]u32;
var south_send_buf: [max_boundary]u32;
var north_send_buf: [max_boundary]u32;

// Received wavelet counters
var num_recv_east: i32 = 0;
var num_recv_west: i32 = 0;
var num_recv_south: i32 = 0;
var num_recv_north: i32 = 0;
var current_round: i32 = 0;

// ===== Host symbol pointers =====

var csr_offsets_ptr: [*]i32 = &csr_offsets;
var csr_adj_ptr: [*]i32 = &csr_adj;
var colors_ptr: [*]i32 = &colors;
var local_num_verts_ptr: [*]i32 = &local_num_verts;
var global_vertex_ids_ptr: [*]i32 = &global_vertex_ids;
var boundary_local_idx_ptr: [*]i32 = &boundary_local_idx;
var boundary_neighbor_gid_ptr: [*]i32 = &boundary_neighbor_gid;
var boundary_direction_ptr: [*]i32 = &boundary_direction;
var num_boundary_ptr: [*]i32 = &num_boundary;
var expected_recv_east_ptr: [*]i32 = &expected_recv_east;
var expected_recv_west_ptr: [*]i32 = &expected_recv_west;
var expected_recv_south_ptr: [*]i32 = &expected_recv_south;
var expected_recv_north_ptr: [*]i32 = &expected_recv_north;

// =====================================================================
// Helper functions
// =====================================================================

fn global_to_local(gid: i32) i32 {
  const n = local_num_verts[0];
  var i: i16 = 0;
  while (i < max_local_verts) : (i += 1) {
    if (@as(i32, i) >= n) break;
    if (global_vertex_ids[i] == gid) return @as(i32, i);
  }
  return -1;
}

fn find_min_available_color() i32 {
  var c: i16 = 0;
  while (c < palette_size) : (c += 1) {
    if (forbidden[c] == 0) return @as(i32, c);
  }
  return -1;
}

fn pack_wavelet(gid: i32, col: i32) u32 {
  const id_part = @as(u32, @as(u16, @as(i16, gid)));
  const col_part = @as(u32, @as(u16, @as(i16, col + 1)));
  return (id_part << 16) | col_part;
}

fn unpack_gid(wval: u32) i32 {
  return @as(i32, @as(i16, @as(u16, wval >> 16)));
}

fn unpack_color(wval: u32) i32 {
  return @as(i32, @as(i16, @as(u16, wval & 0xFFFF))) - 1;
}

fn all_colored() bool {
  const n = local_num_verts[0];
  var v: i16 = 0;
  while (v < max_local_verts) : (v += 1) {
    if (@as(i32, v) >= n) break;
    if (colors[v] < 0) return false;
  }
  return true;
}

fn all_wavelets_received() bool {
  if (num_recv_east < expected_recv_east[0]) return false;
  if (num_recv_west < expected_recv_west[0]) return false;
  if (num_rows > 1) {
    if (num_recv_south < expected_recv_south[0]) return false;
    if (num_recv_north < expected_recv_north[0]) return false;
  }
  return true;
}

fn process_incoming_wavelet(sender_gid: i32, sender_color: i32) void {
  const nbnd = num_boundary[0];
  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    if (@as(i32, b) >= nbnd) break;
    if (boundary_neighbor_gid[b] == sender_gid) {
      remote_recv_color[b] = sender_color;
    }
  }
}

/// Block all receive data tasks (close the receive window).
fn block_all_recv() void {
  @block(recv_east_task_id);
  @block(recv_west_task_id);
  if (num_rows > 1) {
    @block(recv_south_task_id);
    @block(recv_north_task_id);
  }
}

/// Unblock all receive data tasks (open the receive window).
fn unblock_all_recv() void {
  @unblock(recv_east_task_id);
  @unblock(recv_west_task_id);
  if (num_rows > 1) {
    @unblock(recv_south_task_id);
    @unblock(recv_north_task_id);
  }
}

// =====================================================================
// Sync barrier (1D mode): row-reduce + broadcast using data tasks
// =====================================================================
// Two-flag protocol:
//   local_data_done:    set when all expected data wavelets received
//   sync_barrier_done:  set when broadcast received (or sent by P0,0)
//   Both true → activate detect_resolve
//
// Flow:
//   1. All sync tasks start BLOCKED
//   2. Data exchange happens (send + recv wavelets)
//   3. When all data received → on_data_complete():
//      a. Set local_data_done = true
//      b. East PE: sends sync wavelet west
//      c. All PEs: unblock sync_reduce_task (arm for row-reduce signal)
//   4. Sync reduce data task fires (non-east PEs):
//      - Interior: sends sync wavelet west, unblocks broadcast task
//      - West/P0,0: sends broadcast wavelet east, marks sync_barrier_done
//   5. Broadcast data task fires (non-P0,0 PEs):
//      - Set sync_barrier_done, block sync tasks, maybe proceed
//   6. When both flags true → detect_resolve

var local_data_done: bool = false;
var sync_barrier_done: bool = false;
var sync_buf = @zeros([1]u32);

fn send_sync_reduce() void {
  var sync_out = @get_dsd(fabout_dsd, .{
    .extent = 1,
    .fabric_color = sync_reduce_send_color,
    .output_queue = sync_reduce_send_oq,
  });
  var sync_src = @get_dsd(mem1d_dsd, .{
    .tensor_access = |i|{1} -> sync_buf[i],
  });
  @mov32(sync_out, sync_src, .{ .async = true });
}

fn send_sync_bcast() void {
  var bcast_out = @get_dsd(fabout_dsd, .{
    .extent = 1,
    .fabric_color = sync_bcast_color,
    .output_queue = sync_bcast_send_oq,
  });
  var bcast_src = @get_dsd(mem1d_dsd, .{
    .tensor_access = |i|{1} -> sync_buf[i],
  });
  @mov32(bcast_out, bcast_src, .{ .async = true });
}

fn block_sync_tasks() void {
  @block(sync_reduce_task_id);
  @block(sync_bcast_task_id);
}

fn maybe_proceed() void {
  if (local_data_done and sync_barrier_done) {
    @activate(detect_resolve_task_id);
  }
}

/// Called when all expected data wavelets have been received.
fn on_data_complete() void {
  if (use_sync_barrier) {
    local_data_done = true;
    if (is_east_edge) {
      if (is_west_edge) {
        // Single PE: no reduce/broadcast needed, just proceed
        sync_barrier_done = true;
        @activate(detect_resolve_task_id);
        return;
      }
      // East PE: initiate row reduce by sending sync west
      send_sync_reduce();
      // East PE also needs to receive broadcast — unblock bcast task
      @unblock(sync_bcast_task_id);
    } else {
      // Non-east PEs: unblock reduce task to receive sync signal
      @unblock(sync_reduce_task_id);
    }
    // Check if barrier already done (shouldn't happen first time, but safe)
    maybe_proceed();
  } else {
    // No barrier (2D mode): proceed directly
    @activate(detect_resolve_task_id);
  }
}

/// Sync reduce data task: wavelet arrived from east neighbor.
task sync_reduce_recv(wval: u32) void {
  @block(sync_reduce_task_id);  // only process once per round

  if (is_west_edge) {
    // P(0,0): received reduce → send broadcast to all
    send_sync_bcast();
    // P(0,0) won't receive its own broadcast, so mark done directly
    sync_barrier_done = true;
    maybe_proceed();
  } else {
    // Interior PE: forward reduce west, then wait for broadcast
    send_sync_reduce();
    @unblock(sync_bcast_task_id);
  }
}

/// Sync broadcast data task: broadcast wavelet arrived from P(0,0).
task sync_bcast_recv(wval: u32) void {
  @block(sync_bcast_task_id);  // only process once per round
  sync_barrier_done = true;
  maybe_proceed();
}

// =====================================================================
// Phase 1: Speculate — assign tentative colors to uncolored vertices
// =====================================================================

task speculate() void {
  const n = local_num_verts[0];

  var v: i16 = 0;
  while (v < max_local_verts) : (v += 1) {
    if (@as(i32, v) >= n) break;
    tentative[v] = -1;

    if (colors[v] >= 0) continue;

    // Build forbidden set from confirmed neighbor colors
    var c: i16 = 0;
    while (c < palette_size) : (c += 1) {
      forbidden[c] = 0;
    }

    const start = csr_offsets[v];
    const end_idx = csr_offsets[v + 1];
    var e: i32 = start;
    while (e < end_idx) : (e += 1) {
      const neighbor_gid = csr_adj[@as(u16, @as(i16, e))];
      const local_idx = global_to_local(neighbor_gid);
      if (local_idx >= 0) {
        const nc = colors[@as(u16, @as(i16, local_idx))];
        if (nc >= 0 and nc < @as(i32, palette_size)) {
          forbidden[@as(u16, @as(i16, nc))] = 1;
        }
      } else {
        const nbnd = num_boundary[0];
        var b: i16 = 0;
        while (b < max_boundary) : (b += 1) {
          if (@as(i32, b) >= nbnd) break;
          if (boundary_neighbor_gid[b] == neighbor_gid) {
            const rc = remote_recv_color[b];
            if (rc >= 0 and rc < @as(i32, palette_size)) {
              forbidden[@as(u16, @as(i16, rc))] = 1;
            }
          }
        }
      }
    }

    const chosen = find_min_available_color();
    tentative[v] = chosen;
    if (chosen >= 0) {
      colors[v] = chosen;
    }
  }

  // Local conflict check: higher global ID yields
  v = 0;
  while (v < max_local_verts) : (v += 1) {
    if (@as(i32, v) >= n) break;
    if (tentative[v] < 0) continue;

    const my_gid = global_vertex_ids[v];
    const start = csr_offsets[v];
    const end_idx = csr_offsets[v + 1];
    var e: i32 = start;
    while (e < end_idx) : (e += 1) {
      const neighbor_gid = csr_adj[@as(u16, @as(i16, e))];
      const local_idx = global_to_local(neighbor_gid);
      if (local_idx < 0) continue;

      const li = @as(u16, @as(i16, local_idx));
      if (tentative[li] >= 0 and tentative[li] == tentative[v]) {
        if (my_gid > neighbor_gid) {
          colors[v] = -1;
          tentative[v] = -1;
          break;
        }
      }
    }
  }

  @activate(send_boundary_task_id);
}

// =====================================================================
// Phase 2: Send boundary colors as wavelets to neighboring PEs
// =====================================================================

task send_boundary() void {
  const nbnd = num_boundary[0];

  var east_count: u16 = 0;
  var west_count: u16 = 0;
  var south_count: u16 = 0;
  var north_count: u16 = 0;

  // Sort boundary wavelets into per-direction buffers using host-computed
  // boundary_direction[] (0=E, 1=W, 2=S, 3=N).
  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    if (@as(i32, b) >= nbnd) break;
    const li = @as(u16, @as(i16, boundary_local_idx[b]));
    const wval = pack_wavelet(global_vertex_ids[li], colors[li]);
    const dir = boundary_direction[b];

    if (dir == 0) {
      east_send_buf[east_count] = wval;
      east_count += 1;
    } else if (dir == 1) {
      west_send_buf[west_count] = wval;
      west_count += 1;
    }
    // N/S branches compiled only in 2D mode
    if (num_rows > 1) {
      if (dir == 2) {
        south_send_buf[south_count] = wval;
        south_count += 1;
      } else if (dir == 3) {
        north_send_buf[north_count] = wval;
        north_count += 1;
      }
    }
  }

  // ── Send East ──
  if (!is_east_edge and east_count > 0) {
    var east_out = @get_dsd(fabout_dsd, .{
      .fabric_color = send_east_color,
      .extent = max_boundary,
      .output_queue = send_east_oq,
    });
    east_out = @set_dsd_length(east_out, east_count);
    var east_src = @get_dsd(mem1d_dsd, .{
      .tensor_access = |i|{max_boundary} -> east_send_buf[i],
    });
    east_src = @set_dsd_length(east_src, east_count);
    @mov32(east_out, east_src, .{ .async = true });
  }

  // ── Send West ──
  if (!is_west_edge and west_count > 0) {
    var west_out = @get_dsd(fabout_dsd, .{
      .fabric_color = send_west_color,
      .extent = max_boundary,
      .output_queue = send_west_oq,
    });
    west_out = @set_dsd_length(west_out, west_count);
    var west_src = @get_dsd(mem1d_dsd, .{
      .tensor_access = |i|{max_boundary} -> west_send_buf[i],
    });
    west_src = @set_dsd_length(west_src, west_count);
    @mov32(west_out, west_src, .{ .async = true });
  }

  // ── Send South (2D only) ──
  if (num_rows > 1) {
    if (!is_south_edge and south_count > 0) {
      var south_out = @get_dsd(fabout_dsd, .{
        .fabric_color = send_south_color,
        .extent = max_boundary,
        .output_queue = send_south_oq,
      });
      south_out = @set_dsd_length(south_out, south_count);
      var south_src = @get_dsd(mem1d_dsd, .{
        .tensor_access = |i|{max_boundary} -> south_send_buf[i],
      });
      south_src = @set_dsd_length(south_src, south_count);
      @mov32(south_out, south_src, .{ .async = true });
    }
  }

  // ── Send North (2D only) ──
  if (num_rows > 1) {
    if (!is_north_edge and north_count > 0) {
      var north_out = @get_dsd(fabout_dsd, .{
        .fabric_color = send_north_color,
        .extent = max_boundary,
        .output_queue = send_north_oq,
      });
      north_out = @set_dsd_length(north_out, north_count);
      var north_src = @get_dsd(mem1d_dsd, .{
        .tensor_access = |i|{max_boundary} -> north_send_buf[i],
      });
      north_src = @set_dsd_length(north_src, north_count);
      @mov32(north_out, north_src, .{ .async = true });
    }
  }

  // Open receive window for this round
  unblock_all_recv();

  // If we expect no wavelets at all, go straight to barrier/detect
  if (all_wavelets_received()) {
    block_all_recv();
    on_data_complete();
  }
}

// =====================================================================
// Data tasks: receive wavelets from neighboring PEs
// =====================================================================

task recv_east(wval: u32) void {
  process_incoming_wavelet(unpack_gid(wval), unpack_color(wval));
  num_recv_east += 1;
  if (all_wavelets_received()) {
    block_all_recv();
    on_data_complete();
  }
}

task recv_west(wval: u32) void {
  process_incoming_wavelet(unpack_gid(wval), unpack_color(wval));
  num_recv_west += 1;
  if (all_wavelets_received()) {
    block_all_recv();
    on_data_complete();
  }
}

task recv_south(wval: u32) void {
  process_incoming_wavelet(unpack_gid(wval), unpack_color(wval));
  num_recv_south += 1;
  if (all_wavelets_received()) {
    block_all_recv();
    on_data_complete();
  }
}

task recv_north(wval: u32) void {
  process_incoming_wavelet(unpack_gid(wval), unpack_color(wval));
  num_recv_north += 1;
  if (all_wavelets_received()) {
    block_all_recv();
    on_data_complete();
  }
}

// =====================================================================
// Phase 3: Detect boundary conflicts + resolve + loop
// =====================================================================

task detect_resolve() void {
  const nbnd = num_boundary[0];

  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    if (@as(i32, b) >= nbnd) break;

    const li = @as(u16, @as(i16, boundary_local_idx[b]));
    const my_gid = global_vertex_ids[li];
    const nbr_gid = boundary_neighbor_gid[b];

    const my_col = colors[li];
    const remote_col = remote_recv_color[b];

    if (my_col >= 0 and remote_col >= 0 and my_col == remote_col) {
      if (my_gid > nbr_gid) {
        colors[li] = -1;
      }
    }
  }

  current_round += 1;

  if (current_round >= @as(i32, max_rounds)) {
    @activate(exit_task_id);
  } else {
    // Reset recv counters and sync flags for next round
    num_recv_east = 0;
    num_recv_west = 0;
    num_recv_south = 0;
    num_recv_north = 0;
    local_data_done = false;
    sync_barrier_done = false;

    @activate(speculate_task_id);
  }
}

// =====================================================================
// Entry point and exit
// =====================================================================

fn start_coloring() void {
  var b: i16 = 0;
  while (b < max_boundary) : (b += 1) {
    remote_recv_color[b] = -1;
  }

  current_round = 0;
  num_recv_east = 0;
  num_recv_west = 0;
  num_recv_south = 0;
  num_recv_north = 0;
  local_data_done = false;
  sync_barrier_done = false;

  @activate(speculate_task_id);
}

task exit_task() void {
  sys_mod.unblock_cmd_stream();
}

comptime {
  @bind_local_task(speculate, speculate_task_id);
  @bind_local_task(send_boundary, send_boundary_task_id);
  @bind_local_task(detect_resolve, detect_resolve_task_id);
  @bind_local_task(exit_task, exit_task_id);

  // E/W data tasks (always bound)
  @bind_data_task(recv_east, recv_east_task_id);
  @bind_data_task(recv_west, recv_west_task_id);
  @block(recv_east_task_id);
  @block(recv_west_task_id);

  // N/S data tasks (bound only in 2D mode)
  if (num_rows > 1) {
    @bind_data_task(recv_south, recv_south_task_id);
    @bind_data_task(recv_north, recv_north_task_id);
    @block(recv_south_task_id);
    @block(recv_north_task_id);
  }

  // Sync barrier data tasks (1D mode only)
  if (use_sync_barrier) {
    @bind_data_task(sync_reduce_recv, sync_reduce_task_id);
    @bind_data_task(sync_bcast_recv, sync_bcast_task_id);
    @block(sync_reduce_task_id);
    @block(sync_bcast_task_id);
  }

  if (@is_arch("wse3")) {
    // Data queues
    @initialize_queue(send_east_oq, .{ .color = send_east_color });
    @initialize_queue(send_west_oq, .{ .color = send_west_color });
    @initialize_queue(recv_east_iq, .{ .color = recv_east_color });
    @initialize_queue(recv_west_iq, .{ .color = recv_west_color });
    if (num_rows > 1) {
      @initialize_queue(send_south_oq, .{ .color = send_south_color });
      @initialize_queue(send_north_oq, .{ .color = send_north_color });
      @initialize_queue(recv_south_iq, .{ .color = recv_south_color });
      @initialize_queue(recv_north_iq, .{ .color = recv_north_color });
    }
    // Sync barrier queues (1D mode only — reuse queues 4,5)
    if (use_sync_barrier) {
      @initialize_queue(sync_reduce_recv_iq, .{ .color = sync_reduce_recv_color });
      @initialize_queue(sync_reduce_send_oq, .{ .color = sync_reduce_send_color });
      @initialize_queue(sync_bcast_recv_iq, .{ .color = sync_bcast_color });
      @initialize_queue(sync_bcast_send_oq, .{ .color = sync_bcast_color });
    }
  }

  // Export symbols for host communication
  @export_symbol(csr_offsets_ptr, "csr_offsets");
  @export_symbol(csr_adj_ptr, "csr_adj");
  @export_symbol(colors_ptr, "colors");
  @export_symbol(local_num_verts_ptr, "local_num_verts");
  @export_symbol(global_vertex_ids_ptr, "global_vertex_ids");
  @export_symbol(boundary_local_idx_ptr, "boundary_local_idx");
  @export_symbol(boundary_neighbor_gid_ptr, "boundary_neighbor_gid");
  @export_symbol(boundary_direction_ptr, "boundary_direction");
  @export_symbol(num_boundary_ptr, "num_boundary");
  @export_symbol(expected_recv_east_ptr, "expected_recv_east");
  @export_symbol(expected_recv_west_ptr, "expected_recv_west");
  @export_symbol(expected_recv_south_ptr, "expected_recv_south");
  @export_symbol(expected_recv_north_ptr, "expected_recv_north");
  @export_symbol(start_coloring);
}
